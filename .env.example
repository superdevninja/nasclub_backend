# ---------------------------------------------------------------------------
# Local development
# ---------------------------------------------------------------------------
# Run: npm run dev
# Loads .env.development automatically (local MongoDB + localhost URLs).
# Optional: create .env to override any value without editing committed files.

NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/aaa
JWT_SECRET=dev-jwt-secret-change-me
FRONTEND_URL=http://localhost:3000
PORT=5000
